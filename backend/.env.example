# Google Calendar API
# Option A: OAuth (recommended — lets you access all your calendars)
# Run `npm run auth` to generate these via browser flow
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Option B: API Key (read-only, only works for public calendars)
# GOOGLE_API_KEY=your_google_api_key

# Notion
# Create integration at notion.so/my-integrations, share parent page with it
NOTION_API_KEY=your_notion_integration_token
NOTION_PARENT_PAGE_ID=34fe3e22-d20b-8187-9919-c0c030f1eba3

# Server
PORT=8420
